# --- System / IDE ---
.DS_Store
.vscode/
.idea/
*.swp
*.log
.gemini/
.planning/
STATE.md

# --- Environment & Secrets (CRITICAL) ---
.env
.env.*
!.env.example
secrets.yaml
*.pem
*.key

# --- Backend (Rust) ---
backend/target/
backend/storage/videos/*
!backend/storage/videos/.gitkeep

# --- Frontend (Node/React) ---
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/build/
frontend/npm-debug.log*

# --- ML (Python) ---
ml/__pycache__/
ml/*.pyc
ml/.venv/
ml/.python-version
ml/uv.lock
ml/data/videos/*
!ml/data/videos/.gitkeep
# Keep landmarks because Render needs them baked into the image
# But ignore raw video files to save GitHub space/bandwidth

# --- Docker ---
.docker-compose.persistence/
